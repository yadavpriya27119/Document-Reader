# Copy to .env and fill in. Never commit .env.

# Server
PORT=3000
# HOST=0.0.0.0
NODE_ENV=development

# Gemini (required)
GEMINI_API_KEY=
# Optional override
# GEMINI_MODEL=gemini-2.5-flash

# Pinecone (required)
PINECONE_API_KEY=
PINECONE_INDEX=pdfreader

# CORS: comma-separated origins when the SPA is on another host (e.g. https://app.example.com).
# Leave unset in production only if API and SPA share the same origin (e.g. Express serves the built SPA).
# CORS_ORIGIN=https://your-frontend.example.com

# Frontend build: only when the API is on a different origin than the static site (e.g. Vercel + Railway).
# Leave unset when the same server serves both (npm run build:prod && npm run start:prod).
# VITE_API_URL=https://api.example.com

# Chat memory (optional)
# CHAT_MEMORY_MAX_TURNS=10
# CHAT_MEMORY_MAX_HISTORY_CHARS=6000
