{
  "name": "pdfreader",
  "private": true,
  "version": "1.0.0",
  "description": "RAG document Q&A — backend (Express) + frontend (React/Vite)",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "start": "npm run start -w backend",
    "build": "npm run build -w frontend",
    "build:prod": "npm run build -w frontend",
    "start:prod": "cross-env NODE_ENV=production npm run start -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0"
  }
}
